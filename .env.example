# Base URL API (senza slash finale). Se vuoto, la ricerca disponibilità prova prima
# POST /api/v1/availability/search (Vercel + KV), altrimenti mock locale.
# VITE_API_BASE_URL=https://api.example.com

# Password area /admin (opzionale). Se assente o vuota → /admin è aperto in sviluppo.
# In produzione imposta una password e proteggi l’area anche lato server.
# VITE_ADMIN_PASSWORD=your-secure-password

# === Backend Vercel (opzionale, ma necessario per prenotazioni + notifiche + planning condiviso) ===
# Se usi Vercel KV (consigliato), configura queste variabili di ambiente su Vercel:
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
#
# Token/password che l’admin invia alle API (header `x-admin-password`).
# In alternativa puoi usare la stessa VITE_ADMIN_PASSWORD.
# ADMIN_API_PASSWORD=your-secure-password
